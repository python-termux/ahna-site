# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Admin panel (admin.syrflow.com) ───────────────────────────────────────────
# Comma-separated list of emails allowed into the admin panel.
ADMIN_EMAILS=you@example.com
# Service-role key (Supabase → Settings → API → service_role). Server-only, NEVER expose.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Google Maps Scraper ───────────────────────────────────────────────────────
# URL of your running google-maps-scraper Docker container (web mode)
# Run locally:   docker run -v "$PWD/gmapsdata:/gmapsdata" -p 8080:8080 gosom/google-maps-scraper -data-folder /gmapsdata -web
# Deploy on Railway / Fly.io and paste the public URL here
SCRAPER_URL=http://localhost:8080
